<Window x:Class="MonopolyWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Монополия Делюкс" Height="1000" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0" Background="LightGray" Height="30">
            <MenuItem Header="_Игра">
                <MenuItem Header="_Новая игра" Click="NewGameButton_Click"/>
                <MenuItem Header="_Выход" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="_Количество игроков">
                    <MenuItem x:Name="Players2MenuItem" Header="2 игрока" IsCheckable="True" IsChecked="True" Click="SetPlayers2_Click"/>
                    <MenuItem x:Name="Players3MenuItem" Header="3 игрока" IsCheckable="True" Click="SetPlayers3_Click"/>
                    <MenuItem x:Name="Players4MenuItem" Header="4 игрока" IsCheckable="True" Click="SetPlayers4_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Начальные деньги">
                    <MenuItem x:Name="Money1000MenuItem" Header="$1000" IsCheckable="True" Click="SetMoney1000_Click"/>
                    <MenuItem x:Name="Money1500MenuItem" Header="$1500" IsCheckable="True" IsChecked="True" Click="SetMoney1500_Click"/>
                    <MenuItem x:Name="Money2000MenuItem" Header="$2000" IsCheckable="True" Click="SetMoney2000_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Скорость анимации">
                    <MenuItem x:Name="SpeedSlowMenuItem" Header="Медленно" IsCheckable="True" Click="SetSpeedSlow_Click"/>
                    <MenuItem x:Name="SpeedNormalMenuItem" Header="Нормально" IsCheckable="True" IsChecked="True" Click="SetSpeedNormal_Click"/>
                    <MenuItem x:Name="SpeedFastMenuItem" Header="Быстро" IsCheckable="True" Click="SetSpeedFast_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem x:Name="ShowLogMenuItem" Header="Показать журнал" IsCheckable="True" IsChecked="False" Click="ShowLogMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="_Правила игры" Click="RulesMenuItem_Click"/>
                <MenuItem Header="_О программе" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="900"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель с игровым полем -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5" Margin="5" Background="White" Padding="0">
                    <Grid x:Name="BoardGrid" Background="White" Width="850" Height="850">
                        <!-- Клетки будут создаваться программно -->
                    </Grid>
                </Border>
            </ScrollViewer>

            <!-- Правая панель с информацией -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Информация об игроках -->
                <Border Grid.Row="0" BorderBrush="Black" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10" Padding="10" Background="LightYellow">
                    <StackPanel>
                        <TextBlock Text="ИНФОРМАЦИЯ ОБ ИГРОКАХ" FontSize="16" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="DarkBlue"/>

                        <!-- Панель с аватарами игроков -->
                        <WrapPanel x:Name="PlayersAvatarPanel" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                        <ListBox x:Name="PlayersListBox" Height="150" FontSize="12" Background="LightGoldenrodYellow"/>
                    </StackPanel>
                </Border>

                <!-- Текущий игрок и управление -->
                <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10" Padding="10" Background="LightGray">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="ТЕКУЩИЙ ИГРОК" FontSize="14" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="DarkRed"/>

                        <!-- Аватар текущего игрока -->
                        <Border x:Name="CurrentPlayerAvatar" Width="80" Height="80" CornerRadius="40" 
                                Margin="0,5,0,5" HorizontalAlignment="Center" BorderBrush="Black" BorderThickness="2"/>

                        <TextBlock x:Name="CurrentPlayerText" Text="Игрок" 
                                  FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,5"/>

                        <TextBlock x:Name="MoneyText" Text="Деньги: $0" FontSize="14" Margin="0,5,0,5" 
                                  FontWeight="Bold" Foreground="DarkGreen" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="PositionText" Text="Позиция: 0" FontSize="12" Margin="0,5,0,5" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PropertiesCountText" Text="Недвижимость: 0" FontSize="12" Margin="0,5,0,5" HorizontalAlignment="Center"/>

                        <!-- Кубики -->
                        <WrapPanel Margin="0,10,0,10" HorizontalAlignment="Center">
                            <Border x:Name="Dice1Border" Width="70" Height="70" Background="White" 
                                    BorderBrush="Black" BorderThickness="2" CornerRadius="10" Margin="5">
                                <Viewbox>
                                    <TextBlock x:Name="Dice1Text" Text="⚀" FontSize="48" 
                                               FontWeight="Bold" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                                </Viewbox>
                            </Border>
                            <Border x:Name="Dice2Border" Width="70" Height="70" Background="White" 
                                    BorderBrush="Black" BorderThickness="2" CornerRadius="10" Margin="5">
                                <Viewbox>
                                    <TextBlock x:Name="Dice2Text" Text="⚀" FontSize="48" 
                                               FontWeight="Bold" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                                </Viewbox>
                            </Border>
                        </WrapPanel>

                        <!-- Кнопки управления -->
                        <WrapPanel HorizontalAlignment="Center" Margin="0,10">
                            <Button x:Name="RollDiceButton" Content="🎲 БРОСИТЬ" 
                                    Background="LightGreen" FontSize="12" FontWeight="Bold" 
                                    Height="40" Width="90" Margin="2" Click="RollDiceButton_Click"
                                    Cursor="Hand"/>
                            <Button x:Name="BuyPropertyButton" Content="🏠 КУПИТЬ" 
                                    Background="LightBlue" FontSize="12" FontWeight="Bold" 
                                    Height="40" Width="90" Margin="2" Click="BuyPropertyButton_Click"
                                    IsEnabled="False" Cursor="Hand"/>
                            <Button x:Name="EndTurnButton" Content="⏭️ ХОД" 
                                    Background="LightCoral" FontSize="12" FontWeight="Bold" 
                                    Height="40" Width="90" Margin="2" Click="EndTurnButton_Click"
                                    IsEnabled="False" Cursor="Hand"/>
                        </WrapPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="0,5">
                            <Button x:Name="NewGameButton" Content="🔄 НОВАЯ ИГРА" 
                                    Background="LightGoldenrodYellow" FontSize="12" FontWeight="Bold" 
                                    Height="40" Width="140" Margin="2" Click="NewGameButton_Click" Cursor="Hand"/>
                            <Button x:Name="ShowLogButton" Content="📋 ЖУРНАЛ" 
                                    Background="LightGray" FontSize="12" FontWeight="Bold" 
                                    Height="40" Width="140" Margin="2" Click="ShowLogButton_Click" Cursor="Hand"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Всплывающее окно журнала событий -->
        <Popup x:Name="LogPopup" Placement="Center" PopupAnimation="Slide" AllowsTransparency="True" 
               StaysOpen="False" Width="600" Height="400">
            <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5" Background="LightCyan" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ЖУРНАЛ СОБЫТИЙ" FontSize="18" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="DarkGreen"/>

                    <ListBox x:Name="LogListBox" Grid.Row="1" Height="300" FontSize="11" 
                            Background="White" ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <Button Grid.Row="2" Content="ЗАКРЫТЬ" Width="100" Height="30" 
                            Margin="0,10,0,0" HorizontalAlignment="Center"
                            Click="CloseLogPopupButton_Click"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
    